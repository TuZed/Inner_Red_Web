    <script>
        // Initialize Lucide Icons
        lucide.createIcons();
        
        // Team Members Data
        const teamMembers = [
            { name: "Erik Bloodaxe", role: "Creative Director", img: "http://static.photos/people/200x200/1" },
            { name: "Freya Stormborn", role: "Lead Artist", img: "http://static.photos/people/200x200/2" },
            { name: "Bjorn Ironheart", role: "Game Designer", img: "http://static.photos/people/200x200/3" },
            { name: "Sigrid Icevein", role: "Writer", img: "http://static.photos/people/200x200/4" },
            { name: "Ragnar Wolfbane", role: "Lead Programmer", img: "http://static.photos/people/200x200/5" },
            { name: "Astrid Firehair", role: "3D Artist", img: "http://static.photos/people/200x200/6" },
            { name: "Thorvald Grimjaw", role: "Sound Designer", img: "http://static.photos/people/200x200/7" },
            { name: "Ingrid Shadowstep", role: "UI/UX Designer", img: "http://static.photos/people/200x200/8" },
            { name: "Gunnar Thunderfist", role: "Technical Artist", img: "http://static.photos/people/200x200/9" },
            { name: "Helga Raveneye", role: "Producer", img: "http://static.photos/people/200x200/10" },
            { name: "Leif Stormchaser", role: "Level Designer", img: "http://static.photos/people/200x200/11" },
            { name: "Yrsa Frostwind", role: "Animator", img: "http://static.photos/people/200x200/12" },
            { name: "Orin Blackwood", role: "Composer", img: "http://static.photos/people/200x200/13" },
            { name: "Solveig Moonwhisper", role: "Community Manager", img: "http://static.photos/people/200x200/14" },
            { name: "Knut Dragonslayer", role: "QA Lead", img: "http://static.photos/people/200x200/15" }
        ];
        
        // Render Team Grid
        const teamGrid = document.getElementById('team-grid');
        teamMembers.forEach((member, index) => {
            const card = document.createElement('div');
            card.className = 'team-card glass rounded-xl p-4 border border-red-900/20 text-center group cursor-pointer reveal';
            card.style.transitionDelay = `${index * 50}ms`;
            card.innerHTML = `
                <div class="relative mb-4 overflow-hidden rounded-lg aspect-square">
                    <img src="${member.img}" alt="${member.name}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-110">
                    <div class="absolute inset-0 bg-red-600/0 group-hover:bg-red-600/20 transition-colors duration-300"></div>
                </div>
                <h3 class="font-bold text-white mb-1 group-hover:text-red-500 transition-colors">${member.name}</h3>
                <p class="text-xs text-gray-400 uppercase tracking-wider">${member.role}</p>
            `;
            teamGrid.appendChild(card);
        });
        
        // Navigation Scroll Effect
        const navbar = document.getElementById('navbar');
        let lastScroll = 0;
        
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            
            if (currentScroll > 100) {
                navbar.classList.remove('opacity-0', '-translate-y-full');
                navbar.classList.add('opacity-100', 'translate-y-0');
            } else {
                navbar.classList.add('opacity-0', '-translate-y-full');
                navbar.classList.remove('opacity-100', 'translate-y-0');
            }
            
            lastScroll = currentScroll;
        });
        
        // Mobile Menu Toggle
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        
        mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });
        
        // Close mobile menu on link click
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });
        
        // Scroll Reveal Animation
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, observerOptions);
        
        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        
        // Smooth Scroll for Anchor Links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
        
        // Rating System
        const starBtns = document.querySelectorAll('.star-btn');
        let currentRating = 0;
        
        starBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const rating = parseInt(btn.dataset.rating);
                currentRating = rating;
                
                starBtns.forEach((star, index) => {
                    if (index < rating) {
                        star.classList.remove('text-gray-600');
                        star.classList.add('text-red-500');
                    } else {
                        star.classList.add('text-gray-600');
                        star.classList.remove('text-red-500');
                    }
                });
            });
            
            btn.addEventListener('mouseenter', () => {
                const rating = parseInt(btn.dataset.rating);
                starBtns.forEach((star, index) => {
                    if (index < rating) {
                        star.classList.add('text-red-400');
                    } else {
                        star.classList.remove('text-red-400');
                    }
                });
            });
        });
        
        document.getElementById('rating-stars').addEventListener('mouseleave', () => {
            starBtns.forEach((star, index) => {
                star.classList.remove('text-red-400');
                if (index < currentRating) {
                    star.classList.add('text-red-500');
                    star.classList.remove('text-gray-600');
                } else {
                    star.classList.remove('text-red-500');
                    star.classList.add('text-gray-600');
                }
            });
        });
        
        // Form Submissions
        document.getElementById('contact-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalContent = btn.innerHTML;
            
            btn.innerHTML = '<span class="flex items-center gap-2"><i data-lucide="check" class="w-5 h-5"></i> MESSAGE SENT</span>';
            btn.classList.add('bg-green-600');
            btn.classList.remove('from-red-700', 'to-red-600');
            lucide.createIcons();
            
            setTimeout(() => {
                btn.innerHTML = originalContent;
                btn.classList.remove('bg-green-600');
                btn.classList.add('from-red-700', 'to-red-600');
                lucide.createIcons();
                e.target.reset();
            }, 3000);
        });
        
        // Parallax Effect for Hero
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            const parallax = document.querySelector('.parallax-bg');
            if (parallax && scrolled < window.innerHeight) {
                parallax.style.transform = `translateY(${scrolled * 0.5}px)`;
            }
        });
        
        // Performance: Pause animations when tab is hidden
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                document.body.style.animationPlayState = 'paused';
            } else {
                document.body.style.animationPlayState = 'running';
            }
        });
    </script>
